  "private": true,
  "scripts": {
    "android": "npx @react-native-community/cli run-android",
    "ios": "npx @react-native-community/cli run-ios",
    "lint": "eslint .",
    "start": "npx @react-native-community/cli start --reset-cache",
    "test": "jest",
    "copyHermes": "./copy_hermes_dsym.sh matalkforever DD-MM-2025, HH.MM.xcarchive",
    "cleanAndroid": "cd android && ./gradlew clean && cd ..",
    "buildAndroid": "cd android && ./gradlew assembleRelease && cd ..",
    "openStudio": "open -a 'Android Studio' .",
    "runAndroid": "npx @react-native-community/cli run-android",
    "deleteDerivedData": "rm -rf ~/Library/Developer/Xcode/DerivedData/Matalkforever-*",
    "cleanIos": "cd ios && rm -rf build && pod install && cd ..",
    "shake": "adb shell input keyevent 82"
  },
